# Client-side Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-side Supabase (falls back to NEXT_PUBLIC_*)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
SUMMARY_TEMPERATURE=0.2
SUMMARY_MAX_TOKENS=256

# Upstash Redis (rate limiting)
UPSTASH_REDIS_REST_URL=https://your-upstash-url
UPSTASH_REDIS_REST_TOKEN=your-upstash-token
SUMMARY_RATE_LIMIT=10
SUMMARY_RATE_WINDOW="1 h"

# Testing toggles (optional)
GEMINI_TEST_MODE=0
RATE_LIMIT_TEST_MODE=0

# Search fallback if pg_trgm is unavailable
SEARCH_PREFIX_ONLY=0

# Optional legacy base URL (default is same-origin /api)
NEXT_PUBLIC_API_BASE_URL=
